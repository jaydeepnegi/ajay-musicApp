rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: playlists
    // Document ID: {playlistId}
    // Fields:
    //   - id: string (optional)
    //   - name: string (required, size < 100)
    //   - description: string (optional, size < 500)
    //   - ownerId: string (required, immutable)
    //   - createdAt: timestamp (optional)
    //   - songCount: number (optional)
    //
    // Collection: playlists/{playlistId}/songs
    // Document ID: {songId}
    // Fields:
    //   - songId: string (required)
    //   - addedAt: timestamp (required)
    //   - songData: map (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "rana.ajay1991@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidPlaylist(data) {
      return data.keys().hasAll(['name', 'ownerId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId is string &&
             (!('description' in data) || (data.description is string && data.description.size() < 500));
    }

    function isValidPlaylistSong(data) {
      return data.keys().hasAll(['songId', 'addedAt']) &&
             data.songId is string &&
             data.addedAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }

    match /playlists/{playlistId} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPlaylist(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin()) && 
                    isValidPlaylist(request.resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /songs/{songId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/playlists/$(playlistId)).data.ownerId == request.auth.uid || isAdmin());
        allow create: if isAuthenticated() && (get(/databases/$(database)/documents/playlists/$(playlistId)).data.ownerId == request.auth.uid || isAdmin()) && isValidPlaylistSong(request.resource.data);
        allow update: if isAuthenticated() && (get(/databases/$(database)/documents/playlists/$(playlistId)).data.ownerId == request.auth.uid || isAdmin()) && isValidPlaylistSong(request.resource.data);
        allow delete: if isAuthenticated() && (get(/databases/$(database)/documents/playlists/$(playlistId)).data.ownerId == request.auth.uid || isAdmin());
      }
    }
  }
}
